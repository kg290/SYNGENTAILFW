# SAP CPI Specification Generator V2 - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED
# ============================================================================

# Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

# Primary AI Model (default: gemini-2.0-flash)
# AI_MODEL=gemini-2.0-flash

# Thinking model for complex analysis (experimental)
# AI_MODEL_THINKING=gemini-2.0-flash-thinking-exp-01-21

# Use thinking model instead of standard (default: false)
# USE_THINKING_MODEL=false

# ============================================================================
# OPTIMIZATION SETTINGS (V2)
# ============================================================================

# Enable batch API calls - reduces 14 calls to 1-2 (default: true)
# ENABLE_BATCH_MODE=true

# Enable streaming responses for better UX (default: false)
# ENABLE_STREAMING=false

# Enable response caching (default: true)
# ENABLE_AI_CACHING=true

# ============================================================================
# DOCUMENT SETTINGS
# ============================================================================

# Document author name
# DOC_AUTHOR=Your Name or Organization

# Document version
# DOC_VERSION=1.0

# ============================================================================
# AI TUNING
# ============================================================================

# Maximum API retry attempts (default: 3)
# AI_MAX_RETRIES=3

# API timeout in seconds (default: 60)
# AI_TIMEOUT_SECONDS=60

# Sentences per AI summary (default: 5)
# AI_SENTENCE_LIMIT=5

